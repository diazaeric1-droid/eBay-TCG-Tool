# Copy to `.env` (or use .streamlit/secrets.toml) and fill in what you have.
# Everything here is OPTIONAL — the app runs with real sold comps out of the box.

# --- AI card identification (Claude vision) ---
# Without this, you type the card in manually; comps are still real.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- eBay Browse API (optional: enables live ACTIVE comps) ---
# Create an app at https://developer.ebay.com/ and use the client id/secret.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production           # production | sandbox
EBAY_MARKETPLACE=EBAY_US

# --- tuning (optional) ---
# TCG_DATA_DIR=data
# TCG_HTTP_TIMEOUT=20
# TCG_MAX_UPLOAD_MB=25
# TCG_MAX_IMAGE_PIXELS=60000000
# TCG_AI_IMAGE_MAX_DIM=1600
# TCG_COMP_LIMIT=40
