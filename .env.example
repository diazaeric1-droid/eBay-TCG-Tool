# Copy to `.env` (or use .streamlit/secrets.toml) and fill in what you have.
# Everything here is OPTIONAL — the app runs with real sold comps out of the box.

# --- AI card identification: Option A — Ollama (free, local, no account needed) ---
# 1. Install Ollama: https://ollama.com
# 2. Pull a vision model: ollama pull qwen2.5vl:7b   (strong OCR; ~6 GB)
# 3. Set the URL below (default port 11434).
# Other good models: openbmb/minicpm-v2.6 (~5.5 GB), qwen2.5vl:3b (~3.2 GB, low-RAM).
# Avoid plain `llava` — it misreads small card numbers/serials.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# --- AI card identification: Option B — Claude vision (cloud, best quality) ---
# Claude is used in preference to Ollama when both are configured.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- eBay Browse API (optional: enables live ACTIVE comps) ---
# Create an app at https://developer.ebay.com/ and use the client id/secret.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production           # production | sandbox
EBAY_MARKETPLACE=EBAY_US

# --- PSA public API (optional: verify GRADED slabs by cert number) ---
# Request a public-API token from https://www.psacard.com/publicapi
# Enables: enter a cert # in the Analyze tab -> verifies the exact card, grade,
# and PSA population, then pulls comps for that grade. (Identity + population
# only; PSA does not return prices — those still come from 130point.)
PSA_API_TOKEN=

# --- tuning (optional) ---
# TCG_DATA_DIR=data
# TCG_HTTP_TIMEOUT=20
# TCG_MAX_UPLOAD_MB=25
# TCG_MAX_IMAGE_PIXELS=60000000
# TCG_AI_IMAGE_MAX_DIM=1600
# TCG_COMP_LIMIT=40
